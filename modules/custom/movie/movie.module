}

function movie_views_query_alter(Drupal\views\ViewExecutable $view, \Drupal\views\Plugin\views\query\QueryPluginBase $query) { 

if ($view->id() === 'api' && $view->current_display === 'rest_export_1') {
  $alias = $query->ensureTable('node__field_releasedate');
  $now = time();

  $query->addWhere(0, "$alias.field_releasedate_value", $now, '<=');
}

 if ($view->id() == "api_search") {
 $exposed_input = $view->exposed_raw_input;

    // Check if a specific exposed filter value exists.
 if (($view->current_display == 'rest_export_1_old') && (isset($exposed_input['query']) || isset($exposed_input['title_2']))) {
      $filter_value = ($exposed_input['query'])?$exposed_input['query']:$exposed_input['title_2'];
//$filter_value = preg_replace("/[^A-Za-z0-9 ]/", '', $filter_value); 
 $filter_value = trim($filter_value);
$filter_value = explode(" ",$filter_value);
foreach($filter_value as $value){
 $query->addWhere(2, "node_field_data.title", "$value %", "like");
$query->addWhere(2, "node_field_data.title", "% $value", "like");
$query->addWhere(2, "node_field_data.title", "% $value %", "like");
}
  



}





 if (($view->current_display == 'page_1old') || $view->current_display == 'rest_export_1old' && (isset($exposed_input['query']) || isset($exposed_input['title_2']))) {
      $filter_value = ($exposed_input['query'])?$exposed_input['query']:$exposed_input['title_2'];
//$filter_value = preg_replace("/[^A-Za-z0-9 ]/", '', $filter_value); 


if (isset($view->exposed_raw_input['query']) || isset($view->exposed_raw_input['title_2'])) {
     foreach ($query->where as $group_id => $group) {
      foreach ($group['conditions'] as $key => $condition) {
        if (isset($condition['field']) && $condition['field'] === 'node_field_data.title') {
          unset($query->where[$group_id]['conditions'][$key]);
        }
      }
    }
    }


  $filter_value = trim($filter_value);
$query->addWhereExpression(
          2,
          "MATCH(node_field_data.title) AGAINST (:search IN BOOLEAN MODE)",
          [':search' => $filter_value]
        );

  $query->addWhere(2, "node_field_data.title", $filter_value, "SOUNDS like");
// if ($view->current_display == 'page_1'){
// $query->addWhere(2, "node_field_data.title", $filter_value, "LIKE");
$query->addWhereExpression(2,"node_field_data.title REGEXP '^$filter_value$'");

  $query->addOrderBy(NULL, "node_field_data.title REGEXP '^$filter_value$'", 'DESC', 'relevance2');
//}
$query->addWhereExpression(2,"REPLACE(node_field_data.title,' ', '') LIKE '%$filter_value%'");

  $case_expression = "MATCH(node_field_data.title) AGAINST ('$filter_value' IN BOOLEAN MODE)";
   
    
    $query->addOrderBy(NULL, $case_expression, 'DESC', 'relevance');



}

    if ($view->current_display == 'page_2_old' || $view->current_display == 'rest_export_1_old' && (isset($exposed_input['query']) || isset($exposed_input['title_2']))) {
      $filter_value = ($exposed_input['query'])?$exposed_input['query']:$exposed_input['title_2'];
      
      $filter_value = trim($filter_value);

if (isset($view->exposed_raw_input['query']) || isset($view->exposed_raw_input['title_2'])) {
     foreach ($query->where as $group_id => $group) {
      foreach ($group['conditions'] as $key => $condition) {
        if (isset($condition['field']) && $condition['field'] === 'node_field_data.title') {
          unset($query->where[$group_id]['conditions'][$key]);
        }
      }
    }
    }
$filter_value = str_replace("kgf","k.g.f",$filter_value);
$filter_value_exp = explode(" ",$filter_value);

 $query->addWhere(2, "node_field_data.title", "$filter_value_exp[0]", "like");
 $query->addWhere(2, "node_field_data.title", "$filter_value", "like");
 $query->addWhere(2, "node_field_data.title", "$filter_value%", "like");
 $query->addWhere(2, "node_field_data.title", "%$filter_value", "like");
 $query->addWhere(2, "node_field_data.title", "$filter_value", "SOUNDS like");
$filter_value = str_replace("'", "\'", $filter_value);



  $case_expression = "CASE 
      WHEN node_field_data.title LIKE '$filter_value_exp[0]' THEN 0
      WHEN node_field_data.title LIKE '$filter_value' THEN 1
      WHEN node_field_data.title LIKE '$filter_value%' THEN 2
      WHEN node_field_data.title LIKE '%$filter_value' THEN 3
      WHEN node_field_data.title LIKE '%$filter_value%' THEN 4
      ELSE 5
    END";
    
    $query->addOrderBy(NULL, $case_expression, 'ASC', 'priority_sort');
  



}
   
  }

 
 if ($view->id() == "api"){
  $page = \Drupal::request()->get('page');
if($page > 38){
 throw new \Symfony\Component\HttpKernel\Exception\NotFoundHttpException();
 }
 
}

////////////////////////////

if (
  ($view->current_display === 'page_1' || $view->current_display === 'rest_export_1') &&
  (!empty($view->exposed_raw_input['query']) || !empty($view->exposed_raw_input['title_2']))
) {
  $exposed = $view->exposed_raw_input;

  $keyword = !empty($exposed['query'])
    ? $exposed['query']
    : ($exposed['title_2'] ?? '');

  // ✅ Decode URL
  $keyword = urldecode($keyword);

  // ✅ Normalize
  $keyword = trim(mb_strtolower($keyword));
  $keyword = preg_replace('/[\x00-\x1F\x7F]/u', '', $keyword);
  $keyword = trim($keyword, " \t\n\r\0\x0B\\/");
  $keyword = preg_replace('/[;]+/u', '', $keyword);

  // ✅ Language tagging
  $keyword = preg_replace('/\bhindi\b/u', '[hindi]', $keyword);
  $keyword = preg_replace('/\btamil\b/u', '[tamil]', $keyword);
$keyword = preg_replace('/\benglish\b/u', '[english]', $keyword);
$keyword = preg_replace('/\btelugu\b/u', '[telugu]', $keyword);
$keyword = preg_replace('/\bkannada\b/u', '[kannada]', $keyword);

// ✅ Special keyword normalization
$keyword = preg_replace('/\bkgf\b/u', 'k.g.f', $keyword);
$keyword = preg_replace('/\bcid\b/u', 'c.i.d', $keyword);

  if ($keyword === '') {
    return;
  }

  $connection = \Drupal::database();

  // ✅ Clean keyword (ALLOW [ ])
  $keyword_clean = preg_replace('/[^\p{L}\p{N}\[\]\.]+/u', '', $keyword);

  // ✅ Split words
  $words = preg_split('/\s+/u', $keyword, -1, PREG_SPLIT_NO_EMPTY);

  // ✅ Remove useless words
  $stop_words = ['movie', 'full', 'hd', 'film'];
  $filtered_words = [];

  foreach ($words as $word) {
    if (!in_array($word, $stop_words)) {
      $filtered_words[] = $word;
    }
  }

  if (empty($filtered_words)) {
    $filtered_words = $words;
  }

  // ✅ Build LIKE conditions
  $word_conditions = [];
  $word_args = [];

  foreach ($filtered_words as $i => $word) {
    $placeholder = ':word_' . $i;
    $word_conditions[] = "LOWER(node_field_data.title) LIKE $placeholder";
    $word_args[$placeholder] = '%' . $connection->escapeLike($word) . '%';
  }

  // ✅ Remove default Views title filters
  if (!empty($query->where) && is_array($query->where)) {
    foreach ($query->where as $gid => $group) {
      if (empty($group['conditions'])) continue;

      foreach ($group['conditions'] as $cid => $condition) {
        if (!empty($condition['field']) && str_contains($condition['field'], 'title')) {
          unset($query->where[$gid]['conditions'][$cid]);
        }
      }

      if (!empty($query->where[$gid]['conditions'])) {
        $query->where[$gid]['conditions'] = array_values($query->where[$gid]['conditions']);
      }
    }
  }

  // ✅ Clean title (KEEP [ ])
  $title_clean = "LOWER(REGEXP_REPLACE(node_field_data.title, '[:\\- ]', ''))";

  // ✅ Language normalized title (extra boost)
  $title_lang = "
    LOWER(
      REPLACE(
        REPLACE(node_field_data.title, 'hindi', '[Hindi]'),
        'tamil', '[Tamil]'
      )
    )
  ";

  // ✅ FINAL CONDITIONS
  $conditions = [];

  if (!empty($keyword_clean)) {
    $conditions[] = "$title_clean LIKE :clean_match";
  }

  if (!empty($word_conditions)) {
    $conditions[] = '(' . implode(' OR ', $word_conditions) . ')';
  }

  $conditions[] = "LOWER(node_field_data.title) LIKE :full_match";
  $conditions[] = "$title_lang LIKE :lang_match";

  $query->addWhereExpression(
    0,
    '(' . implode(' OR ', $conditions) . ')',
    [
      ':clean_match' => '%' . $keyword_clean . '%',
      ':full_match' => '%' . $connection->escapeLike($keyword) . '%',
      ':lang_match' => '%' . $connection->escapeLike($keyword) . '%',
    ] + $word_args
  );

  // ✅ SMART ORDERING
  $case_exact = $connection->quote($keyword_clean);
  $case_start = $connection->quote($keyword_clean . '%');
  $case_word = $connection->quote('%' . $connection->escapeLike($filtered_words[0]) . '%');

  $case = "
    CASE
      WHEN $title_clean = '$keyword' THEN 0
      WHEN $title_clean LIKE $case_start THEN 1
      WHEN LOWER(node_field_data.title) LIKE $case_word THEN 2
      WHEN $title_lang LIKE " . $connection->quote('%' . $keyword . '%') . " THEN 3
      ELSE 4
    END
  ";

  $query->addOrderBy(NULL, $case, 'ASC', 'search_rank');
}

/////////////////////////////


 if ($view->id() == "detail_movie"){
 //exit;
 $link_array = explode('/',$_SERVER["REQUEST_URI"]);
     $nid = end($link_array);
   $context ='';
  if(intval($nid)){
   $node2 = \Drupal\movie\ReplaceLanguageCode::replaceLangcode($nid,$context);
  }
 
}



}

